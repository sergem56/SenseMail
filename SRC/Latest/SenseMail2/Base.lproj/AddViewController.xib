                                            <constraints>
                                                <constraint firstAttribute="height" constant="78" id="Sit-3v-G83"/>
                                            </constraints>
                                            <string key="text">You can add a single 256-bit certificate that will be used instead of a password for a message. The other part should scan a generated QR-code to add a certificate to be able to read your mails. This certificate is protected by its own password.</string>
                                            <fontDescription key="fontDescription" type="system" pointSize="13"/>
                                            <color key="textColor" systemColor="secondaryLabelColor" red="0.23529411759999999" green="0.23529411759999999" blue="0.26274509800000001" alpha="0.59999999999999998" colorSpace="custom" customColorSpace="sRGB"/>
