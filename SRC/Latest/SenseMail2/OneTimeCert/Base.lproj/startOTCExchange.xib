                                    <rect key="frame" x="8" y="162.5" width="398" height="109"/>
                                    <string key="text">IMPORTANT! To exchange certificates you need to place both devices near each other.

One device will generate the certificates, the other will simply receive them.

What would you like to do?</string>
                                    <fontDescription key="fontDescription" type="system" pointSize="13"/>
                                    <nil key="textColor"/>
                                    <nil key="highlightedColor"/>
                                    <variation key="heightClass=regular-widthClass=regular">
